<?xml version="1.0" ?>
<sdf version="1.9">
  <!-- Standalone drone model definition ready for flight testing -->
  <!-- Aerodynamics tuned for T-Motor F60 and 5.1 inch propellers on 6S -->
  <model name="dropper_drone">
    
    <!-- 1. MAIN FRAME -->
    <link name="base_link">
      <!-- IMU sensor definition -->
      <sensor name="imu_sensor" type="imu">
        <always_on>1</always_on>
        <update_rate>250</update_rate>
        <imu>
          <angular_velocity>
            <x><noise type="gaussian"><mean>0</mean><stddev>0.0002</stddev></noise></x>
            <y><noise type="gaussian"><mean>0</mean><stddev>0.0002</stddev></noise></y>
            <z><noise type="gaussian"><mean>0</mean><stddev>0.0002</stddev></noise></z>
          </angular_velocity>
          <linear_acceleration>
            <x><noise type="gaussian"><mean>0</mean><stddev>0.017</stddev></noise></x>
            <y><noise type="gaussian"><mean>0</mean><stddev>0.017</stddev></noise></y>
            <z><noise type="gaussian"><mean>0</mean><stddev>0.017</stddev></noise></z>
          </linear_acceleration>
        </imu>
      </sensor>

      <inertial>
        <mass>1.310</mass>
        <pose>-0.002060 -0.001083 0.034620 0 0 0</pose>
        <inertia>
          <ixx>0.002289119</ixx>
          <iyy>0.002840295</iyy>
          <izz>0.003642920</izz>
          <ixy>-0.000036994</ixy>
          <ixz>-0.000103084</ixz>
          <iyz>-0.000046559</iyz>
        </inertia>
      </inertial>
      <visual name="base_link_visual">
        <pose>0 0 0 0 0 0</pose>
        <geometry>
          <mesh>
            <uri>../01_mechanics/CAD/Drone_assembly_gazebo.obj</uri>
          </mesh>
        </geometry>
      </visual>
      <collision name="base_link_collision">
        <pose>0.0 0.0 0.01 0 0 0</pose>
        <geometry>
          <box>
            <!-- Dimensions based on CAD measurements (X: 196.79mm, Y: 191.75mm, Z: 5mm). -->
            <size>0.197 0.192 0.02</size>
          </box>
        </geometry>
      </collision>
    </link>

    <!-- 2. ROTORS DEFINITION -->
    <!-- ROTOR 0: Front-Right (CCW) -->
    <link name="rotor_0">
      <!-- WARNING: Pose offsets (0.15) are still placeholders, waiting for CAD measurements -->
      <pose>0.088388 -0.088388 0.022715  0 0 0</pose> 
      <inertial>
        <mass>0.005</mass>
        <pose>0.000001 -0.008448 0 0 0 0</pose>
        <inertia>
          <ixx>0.000001622</ixx>
          <iyy>0.000001622</iyy>
          <izz>0.000001</izz>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyz>0</iyz>
        </inertia>
      </inertial>

      <visual name="rotor_0_visual">
        <geometry>
          <mesh>
            <uri>../01_mechanics/CAD/CCW_propeller.obj</uri>
          </mesh>
        </geometry>
      </visual>
    </link>
    <joint name="rotor_0_joint" type="revolute">
      <parent>base_link</parent>
      <child>rotor_0</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-1e+16</lower>
          <upper>1e+16</upper>
        </limit> 
      </axis>
    </joint>

    <!-- ROTOR 1: Back-Left (CCW) -->
    <link name="rotor_1">
      <!-- WARNING: Pose offsets (0.15) are still placeholders -->
      <pose>-0.088388 0.088388 0.022715  0 0 0</pose> 
      <inertial>
        <mass>0.005</mass>
        <pose>0.000001 -0.008448 0 0 0 0</pose>
        <inertia>
          <ixx>0.000001622</ixx>
          <iyy>0.000001622</iyy>
          <izz>0.000001</izz>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyz>0</iyz>
        </inertia>
      </inertial>

      <visual name="rotor_1_visual">
        <geometry>
          <mesh>
            <uri>../01_mechanics/CAD/CCW_propeller.obj</uri>
          </mesh>
        </geometry>
      </visual>
    </link>
    <joint name="rotor_1_joint" type="revolute">
      <parent>base_link</parent>
      <child>rotor_1</child>
      <axis>
        <xyz>0 0 1</xyz> 
        <limit>
          <lower>-1e+16</lower>
          <upper>1e+16</upper>
        </limit> 
      </axis>
    </joint>

    <!-- ROTOR 2: Front-Left (CW) -->
    <link name="rotor_2">
      <!-- WARNING: Pose offsets (0.15) are still placeholders -->
      <pose>0.088388 0.088388 0.022715 0 0 0</pose> 
      <inertial>
        <mass>0.005</mass>
        <pose>0.000001 -0.008448 0 0 0 0</pose>
        <inertia>
          <ixx>0.000001622</ixx>
          <iyy>0.000001622</iyy>
          <izz>0.000001</izz>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyz>0</iyz>
        </inertia>
      </inertial>

      <visual name="rotor_2_visual">
        <geometry>
          <mesh>
            <uri>../01_mechanics/CAD/CW_propeller.obj</uri>
          </mesh>
        </geometry>
      </visual>
    </link>
    <joint name="rotor_2_joint" type="revolute">
      <parent>base_link</parent>
      <child>rotor_2</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-1e+16</lower>
          <upper>1e+16</upper>
        </limit>
      </axis>
    </joint>
    <!-- ROTOR 3: Back-Right (CW) -->
    <link name="rotor_3">
      <pose>-0.088388 -0.088388 0.022715 0 0 0</pose> 
      <inertial>
        <mass>0.005</mass>
        <pose>0.000001 -0.008448 0 0 0 0</pose>
        <inertia>
          <ixx>0.000001622</ixx>
          <iyy>0.000001622</iyy>
          <izz>0.000001</izz>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyz>0</iyz>
        </inertia>
      </inertial>

      <visual name="rotor_3_visual">
        <geometry>
          <mesh>
            <uri>../01_mechanics/CAD/CW_propeller.obj</uri>
          </mesh>
        </geometry>
      </visual>
    </link>
    <joint name="rotor_3_joint" type="revolute">
      <parent>base_link</parent>
      <child>rotor_3</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-1e+16</lower>
          <upper>1e+16</upper>
        </limit>
      </axis>
    </joint>

    <!-- Link representing the moving drop pin -->
    <link name="drop_pin_link">
      <!-- Starting position based on Blender 3D cursor coordinates -->
      <pose>0.009 -0.0001 -0.03895 0 0 0</pose>
      <inertial>
        <mass>0.005</mass>
        <inertia>
          <ixx>0.0000001</ixx>
          <iyy>0.0000001</iyy>
          <izz>0.0000001</izz>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyz>0</iyz>
        </inertia>
      </inertial>
      
      <!-- Simplified collision geometry to avoid physics engine lag -->
      <collision name="drop_pin_collision">
        <!-- Rotated 90 degrees on Y axis (1.5708 rad) to align cylinder with X axis -->
        <pose>-0.015 0 0 0 1.5708 0</pose>
        <geometry>
          <cylinder>
            <radius>0.0024</radius>
            <length>0.03</length>
          </cylinder>
        </geometry>
      </collision>

      <!-- Visual representation using the provided CAD file -->
      <visual name="drop_pin_visual">
        <geometry>
          <mesh>
            <!-- Adjust this path if your Pin.obj is located in a different subfolder -->
            <uri>../01_mechanics/CAD/Pin.obj</uri>
          </mesh>
        </geometry>
      </visual>
    </link>

    <!-- Prismatic joint enabling linear movement along the X axis -->
    <joint name="drop_pin_joint" type="prismatic">
      <parent>base_link</parent>
      <child>drop_pin_link</child>
      <axis>
        <xyz>-1 0 0</xyz>
        <limit>
          <!-- Lower limit is the fully inserted position -->
          <lower>0</lower>
          <!-- Upper limit is the fully extracted position (16 millimeters) -->
          <upper>0.016</upper>
          <effort>1000000</effort>
        </limit>
        <dynamics>
          <!-- Small damping value to prevent physics oscillations -->
          <damping>0.01</damping>
          <friction>0.005</friction>
        </dynamics>
      </axis>
    </joint>
    
    <!-- 2.5 DIAGNOSTIC PLUGINS -->
    <!-- Publishes joint states to /world/drone_world/model/dropper_drone/joint_state -->
    <plugin filename="gz-sim-joint-state-publisher-system" name="gz::sim::systems::JointStatePublisher">
    </plugin>
    
    <!-- 3. AERODYNAMICS PLUGINS (IRIS PASSIVE STYLE) -->
    <!-- Removed all commandSubTopics to force physics-based lift calculation -->
    <plugin filename="gz-sim-multicopter-motor-model-system" name="gz::sim::systems::MulticopterMotorModel">
      <jointName>rotor_0_joint</jointName>
      <linkName>rotor_0</linkName>
      <turningDirection>ccw</turningDirection>
      <maxRotVelocity>3665</maxRotVelocity>
      <motorConstant>0.000041</motorConstant>
      <momentConstant>0.016</momentConstant>
      <!-- Explicitly defined actuator number to solve log error -->
      <actuator_number>0</actuator_number>
      <motorType>velocity</motorType>
      <!-- Slowdown matched to ArduPilotPlugin multiplier (20x) -->
      <rotorVelocitySlowdownSim>10</rotorVelocitySlowdownSim>
    </plugin>

    <plugin filename="gz-sim-multicopter-motor-model-system" name="gz::sim::systems::MulticopterMotorModel">
      <jointName>rotor_1_joint</jointName>
      <linkName>rotor_1</linkName>
      <turningDirection>ccw</turningDirection>
      <maxRotVelocity>3665</maxRotVelocity>
      <motorConstant>0.000041</motorConstant>
      <momentConstant>0.016</momentConstant>
      <actuator_number>1</actuator_number>
      <motorType>velocity</motorType>
      <rotorVelocitySlowdownSim>10</rotorVelocitySlowdownSim>
    </plugin>

    <plugin filename="gz-sim-multicopter-motor-model-system" name="gz::sim::systems::MulticopterMotorModel">
      <jointName>rotor_2_joint</jointName>
      <linkName>rotor_2</linkName>
      <turningDirection>cw</turningDirection>
      <maxRotVelocity>3665</maxRotVelocity>
      <motorConstant>0.000041</motorConstant>
      <momentConstant>0.016</momentConstant>
      <actuator_number>2</actuator_number>
      <motorType>velocity</motorType>
      <rotorVelocitySlowdownSim>10</rotorVelocitySlowdownSim>
    </plugin>

    <plugin filename="gz-sim-multicopter-motor-model-system" name="gz::sim::systems::MulticopterMotorModel">
      <jointName>rotor_3_joint</jointName>
      <linkName>rotor_3</linkName>
      <turningDirection>cw</turningDirection>
      <maxRotVelocity>3665</maxRotVelocity>
      <motorConstant>0.000041</motorConstant>
      <momentConstant>0.016</momentConstant>
      <actuator_number>3</actuator_number>
      <motorType>velocity</motorType>
      <rotorVelocitySlowdownSim>10</rotorVelocitySlowdownSim>
    </plugin>

    <!-- ArduPilot integration plugin for Gazebo Harmonic -->
    <plugin filename="ArduPilotPlugin" name="ArduPilotPlugin">
      <!-- Local network address for SITL connection -->
      <fdm_addr>127.0.0.1</fdm_addr>
      <!-- Port for receiving data from SITL -->
      <fdm_port_in>9002</fdm_port_in>
      <!-- Maximum timeout count before connection is dropped -->
      <connectionTimeoutMaxCount>5</connectionTimeoutMaxCount>
      <!-- Synchronization lock step with Gazebo physics -->
      <lock_step>1</lock_step>
      <!-- Model name mapping -->
      <modelName>dropper_drone</modelName>
      <!-- IMU sensor name mapping -->
      <imuName>imu_sensor</imuName>

      <!-- Control channels for CCW motors -->
      <control channel="0">
        <jointName>rotor_0_joint</jointName>
        <useForce>0</useForce>
        <!-- Positive multiplier for standard rotation -->
        <multiplier>366.5</multiplier>
        <!-- Zero offset for DShot normalized 0.0-1.0 signal -->
        <offset>0</offset>
        <servo_min>1000</servo_min>
        <servo_max>2000</servo_max>
        <type>VELOCITY</type>
        <p_gain>0.01</p_gain>
        <!-- Clamp blocking any negative mathematical noise -->
        <cmd_min>0</cmd_min>
        <cmd_max>366.5</cmd_max>
      </control>

      <control channel="1">
        <jointName>rotor_1_joint</jointName>
        <useForce>0</useForce>
        <!-- Positive multiplier for standard rotation -->
        <multiplier>366.5</multiplier>
        <!-- Zero offset for DShot normalized 0.0-1.0 signal -->
        <offset>0</offset>
        <servo_min>1000</servo_min>
        <servo_max>2000</servo_max>
        <type>VELOCITY</type>
        <p_gain>0.01</p_gain>
        <!-- Clamp blocking any negative mathematical noise -->
        <cmd_min>0</cmd_min>
        <cmd_max>366.5</cmd_max>
      </control>

      <!-- Control channels for CW motors -->
      <control channel="2">
        <jointName>rotor_2_joint</jointName>
        <useForce>0</useForce>
        <!-- Negative multiplier to reverse joint velocity for CW rotation -->
        <multiplier>366.5</multiplier>
        <!-- Zero offset for DShot normalized 0.0-1.0 signal -->
        <offset>0</offset>
        <servo_min>1000</servo_min>
        <servo_max>2000</servo_max>
        <type>VELOCITY</type>
        <p_gain>0.01</p_gain>
        <!-- Negative clamps allowing reverse velocity and blocking positive noise -->
        <cmd_min>0</cmd_min>
        <cmd_max>366.5</cmd_max>
      </control>

      <control channel="3">
        <jointName>rotor_3_joint</jointName>
        <useForce>0</useForce>
        <!-- Negative multiplier to reverse joint velocity for CW rotation -->
        <multiplier>366.5</multiplier>
        <!-- Zero offset for DShot normalized 0.0-1.0 signal -->
        <offset>0</offset>
        <servo_min>1000</servo_min>
        <servo_max>2000</servo_max>
        <type>VELOCITY</type>
        <p_gain>0.01</p_gain>
        <!-- Negative clamps allowing reverse velocity and blocking positive noise -->
        <cmd_min>0</cmd_min>
        <cmd_max>366.5</cmd_max>
      </control>

      <control channel="4">
        <jointName>drop_pin_joint</jointName>
        <useForce>1</useForce>
        <multiplier>0.016</multiplier>
        <offset>0</offset>
        <servo_min>1000</servo_min>
        <servo_max>2000</servo_max>
        <type>POSITION</type>
        <p_gain>10.0</p_gain>
        <cmd_min>-1.0</cmd_min>
        <cmd_max>1.0</cmd_max>
      </control>
    </plugin>

  </model>
</sdf>