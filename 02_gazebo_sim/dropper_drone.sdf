<?xml version="1.0" ?>
<sdf version="1.9">
  <model name="dropper_drone">
    
    <pose>0 0 0 0 0 0</pose>

    <link name="base_link">
      <sensor name="imu_sensor" type="imu">
        <always_on>1</always_on>
        <update_rate>1000</update_rate>
      </sensor>

      <inertial>
        <mass>1.310</mass>
        <pose>0.0 0.0 0.03000 0 0 0</pose>
        <inertia>
          <ixx>0.0034</ixx>
          <iyy>0.0043</iyy>
          <izz>0.0055</izz>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyz>0.0</iyz>
        </inertia>
      </inertial>
      
      <visual name="base_link_visual">
        <pose>0 0 0 0 0 0</pose>
        <geometry>
          <mesh><uri>../01_mechanics/CAD/Drone_assembly_gazebo.obj</uri></mesh>
        </geometry>
      </visual>
      
      <collision name="base_link_collision">
        <pose>0.0 0.0 0.01 0 0 0</pose>
        <geometry>
          <box><size>0.197 0.192 0.02</size></box>
        </geometry>
      </collision>
    </link>

    <link name="rotor_0">
      <pose>0.088388 -0.088388 0.022715 0 0 0</pose> 
      <inertial>
        <mass>0.023</mass>
        <pose>0 0 0 0 0 0</pose>
        <inertia><ixx>0.000008</ixx><iyy>0.000008</iyy><izz>0.000015</izz><ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia>
      </inertial>
      <visual name="rotor_0_visual">
        <geometry><mesh><uri>../01_mechanics/CAD/CCW_propeller.obj</uri></mesh></geometry>
      </visual>
    </link>
    <joint name="rotor_0_joint" type="revolute">
      <parent>base_link</parent>
      <child>rotor_0</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit><lower>-1e+16</lower><upper>1e+16</upper></limit>
        <dynamics><damping>0.0002</damping><friction>0.0002</friction></dynamics>
      </axis>
    </joint>

    <link name="rotor_1">
      <pose>-0.088388 0.088388 0.022715 0 0 0</pose> 
      <inertial>
        <mass>0.023</mass>
        <pose>0 0 0 0 0 0</pose>
        <inertia><ixx>0.000008</ixx><iyy>0.000008</iyy><izz>0.000015</izz><ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia>
      </inertial>
      <visual name="rotor_1_visual">
        <geometry><mesh><uri>../01_mechanics/CAD/CCW_propeller.obj</uri></mesh></geometry>
      </visual>
    </link>
    <joint name="rotor_1_joint" type="revolute">
      <parent>base_link</parent>
      <child>rotor_1</child>
      <axis>
        <xyz>0 0 1</xyz> 
        <limit><lower>-1e+16</lower><upper>1e+16</upper></limit>
        <dynamics><damping>0.0002</damping><friction>0.0002</friction></dynamics>
      </axis>
    </joint>

    <link name="rotor_2">
      <pose>0.088388 0.088388 0.022715 0 0 0</pose> 
      <inertial>
        <mass>0.023</mass>
        <pose>0 0 0 0 0 0</pose>
        <inertia><ixx>0.000008</ixx><iyy>0.000008</iyy><izz>0.000015</izz><ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia>
      </inertial>
      <visual name="rotor_2_visual">
        <geometry><mesh><uri>../01_mechanics/CAD/CW_propeller.obj</uri></mesh></geometry>
      </visual>
    </link>
    <joint name="rotor_2_joint" type="revolute">
      <parent>base_link</parent>
      <child>rotor_2</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit><lower>-1e+16</lower><upper>1e+16</upper></limit>
        <dynamics><damping>0.0002</damping><friction>0.0002</friction></dynamics>
      </axis>
    </joint>
    
    <link name="rotor_3">
      <pose>-0.088388 -0.088388 0.022715 0 0 0</pose> 
      <inertial>
        <mass>0.023</mass>
        <pose>0 0 0 0 0 0</pose>
        <inertia><ixx>0.000008</ixx><iyy>0.000008</iyy><izz>0.000015</izz><ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia>
